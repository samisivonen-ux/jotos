{
  "name": "jotos",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source GPX route viewer and map video export tool.",
  "scripts": {
    "start": "vite --host 127.0.0.1",
    "dev": "vite --host 127.0.0.1",
    "dev:connect": "VITE_ENABLE_INTERVALS_CONNECT=true VITE_TELEGRAM_VIDEO_UPLOAD_URL_ENDPOINT=https://7fdqktp1k3.execute-api.eu-west-1.amazonaws.com/v1/video/upload-url VITE_TELEGRAM_VIDEO_FINALIZE_ENDPOINT=https://7fdqktp1k3.execute-api.eu-west-1.amazonaws.com/v1/video/finalize vite --host 127.0.0.1",
    "build": "vite build",
    "build:connect": "VITE_ENABLE_INTERVALS_CONNECT=true VITE_TELEGRAM_VIDEO_UPLOAD_URL_ENDPOINT=https://7fdqktp1k3.execute-api.eu-west-1.amazonaws.com/v1/video/upload-url VITE_TELEGRAM_VIDEO_FINALIZE_ENDPOINT=https://7fdqktp1k3.execute-api.eu-west-1.amazonaws.com/v1/video/finalize vite build --outDir dist-connect --base /connect/",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "maplibre-gl": "^5.24.0",
    "mediabunny": "^1.49.0",
    "pmtiles": "^4.4.1",
    "typescript": "latest",
    "vite": "latest"
  }
}
